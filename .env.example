# Slack incoming webhook URL (https://api.slack.com/messaging/webhooks)
SLACK_WEBHOOK_URL=

# Discord webhook URL (Server Settings → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=

# Optional: override today's date for testing (YYYY-MM-DD)
# PROMPT_DATE=2026-06-22

# Optional: IANA timezone for "today" when no date is set (default: America/Los_Angeles)
# PROMPT_TIMEZONE=America/New_York

# NASA Open APIs (api.nasa.gov) — free key at https://api.nasa.gov/
# Used when a source still points at api.nasa.gov (e.g. open-data index entries).
# NASA_API_KEY=your_key_here
